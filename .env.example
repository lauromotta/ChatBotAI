# ============================================================
# ChatBotAI — Configuração de Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com dados reais!

# ------------------------------------------------------------
# GEMINI AI (obrigatório)
# Obtenha sua chave gratuita em: https://aistudio.google.com
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# EVOLUTION API (obrigatório)
# Instale via Docker: https://doc.evolution-api.com
# ------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE=meu-bot

# ------------------------------------------------------------
# CONFIGURAÇÃO DO BOT
# ------------------------------------------------------------
# Prefixo de comando para acionar a IA
BOT_COMMAND_PREFIX=/bot

# Personalidade e comportamento do bot (System Prompt)
BOT_SYSTEM_PROMPT=Você é um assistente inteligente chamado BotAI. Responda sempre em português brasileiro, de forma clara, objetiva e amigável. Seja conciso nas respostas (máximo 3 parágrafos). Se não souber a resposta, diga honestamente que não sabe.

# Tempo em minutos de inatividade antes de limpar o histórico de conversa
SESSION_TTL_MINUTES=30
